// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum InvoiceStatus {
  PENDING
  SENT
  PAID
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String         // Hashed password
  name          String?
  role          String         @default("user") // "admin" or "user"
  createdAt     DateTime       @default(now())
  
  notifications Notification[]
  @@map("user")
}

model Customer {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(100)
  location    String @db.VarChar(100)
  postCode    Int
  suburb      String @db.VarChar(100)
  phoneNumber String @db.VarChar(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations (One Customer can have many Schedules and Transactions)
  schedules    Schedule[]
  transactions CustomerTransaction[]
  invoices     Invoice[]

  @@map("customers")
}

model ProductAndService {
  id                 Int         @id @default(autoincrement())
  productType        ProductType
  productServiceName String?     @db.VarChar(255)
  unitPrice          Decimal     @db.Decimal(10, 2)
  unit               String      @db.VarChar(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations (One Product/Service can be in many Schedules and Transactions)
  schedules    Schedule[]
  transactions CustomerTransaction[]

  @@map("products_and_services")
}

model Schedule {
  id              Int       @id @default(autoincrement())
  customerId      Int
  productId       Int
  lastServiceDate DateTime?
  nextServiceDate DateTime
  time            DateTime  @db.Time()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer     Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product      ProductAndService @relation(fields: [productId], references: [id], onDelete: Restrict)
  Notification Notification?

  @@index([customerId])
  @@index([productId])
  @@map("schedules")
}

model CustomerTransaction {
  id              Int      @id @default(autoincrement())
  customerId      Int
  productId       Int
  invoiceId       Int?
  date            DateTime @default(now()) @db.DateTime
  quantity        Int
  unitPrice       Decimal  @db.Decimal(10, 2)
  unit            String   @db.VarChar(40)
  totalLineAmount Decimal  @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  ProductAndService @relation(fields: [productId], references: [id], onDelete: Restrict)
  invoice  Invoice? @relation("InvoiceTransactions", fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([productId])
  @@map("customer_transactions")
}

model Notification {
  id         Int      @id @default(autoincrement())
  scheduleId Int      @unique
  userId     Int
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule? @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduleId])
  @@map("notifications")
}

model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNumber String   @unique
  customerId    Int
  issueDate     DateTime @default(now())
  totalAmount   Decimal  @db.Decimal(10, 2) 
  status        InvoiceStatus @default(PENDING)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  transactions  CustomerTransaction[] @relation("InvoiceTransactions")

  @@index([customerId])
  @@map("invoices")
}
